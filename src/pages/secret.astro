import Card from '../components/CardPink.astro';
import Card2 from '../components/Card2.astro';
---

<Layout title="UwU">
	<main>
		<link rel="icon" type="image/png" href="https://cdn-icons-png.flaticon.com/512/410/410192.png">
			<path
				fill-rule="evenodd"
				clip-rule="evenodd"
